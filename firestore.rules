rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user has admin claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if true; // Everyone can see job listings
      allow write: if isAdmin(); // Only admin can create/edit/delete
    }

    // Applications collection
    match /applications/{appId} {
      allow create: if true; // Anyone can submit an application
      allow read, delete: if isAdmin(); // Only admin can view/archive applications
      allow update: if false; // Applications shouldn't be edited after submission
    }

    // Contacts collection
    match /contacts/{contactId} {
      allow create: if true; // Anyone can submit a contact message
      allow read, delete: if isAdmin(); // Only admin can view/delete
      allow update: if false; // Messages can't be edited after submission
    }
  }
}
